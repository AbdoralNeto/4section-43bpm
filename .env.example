# Configurações do Supabase para o SisCarga-PM
# Renomeie este arquivo para .env e preencha com as credenciais da sua instância do Supabase.

# URL do projeto Supabase (ex: https://abcdeflkasdfasdfasdf.supabase.co)
VITE_SUPABASE_URL=seu_supabase_url_aqui

# Chave pública anônima do Supabase (Anon Key)
VITE_SUPABASE_ANON_KEY=sua_supabase_anon_key_aqui
